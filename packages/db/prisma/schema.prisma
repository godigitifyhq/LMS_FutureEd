generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ENUMS — Only for values that never change
// ─────────────────────────────────────────

enum Role {
  EMPLOYEE
  SUB_ADMIN
  ADMIN
}

enum LeadStatus {
  NEW
  ATTEMPTED_CONTACT
  CONNECTED
  INTERESTED
  FOLLOW_UP_SCHEDULED
  APPLICATION_SENT
  UNDER_VALIDATION
  CONFIRMED
  LOST
  NOT_INTERESTED
  NOT_REACHABLE
  DUPLICATE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
}

enum QualificationLevel {
  TENTH
  TWELFTH
  GRADUATION
  POST_GRADUATION
  OTHER
}

enum InteractionType {
  NOTE
  CALL
  EMAIL
  SMS
  MEETING
  DOCUMENT_UPLOADED
  STATUS_CHANGED
}

// ─────────────────────────────────────────
// BRANCH
// Physical office location.
// One now (Bokaro), multi-branch ready.
// ─────────────────────────────────────────

model Branch {
  id        String   @id @default(cuid())
  name      String
  city      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  leads Lead[]
}

// ─────────────────────────────────────────
// USER
// All roles live in one table.
// Password always stored as bcrypt hash.
// ─────────────────────────────────────────

model User {
  id           String  @id @default(cuid())
  name         String
  email        String  @unique
  phone        String?
  passwordHash String
  role         Role    @default(EMPLOYEE)
  isActive     Boolean @default(true)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assignedLeads    Lead[]              @relation("AssignedTo")
  createdLeads     Lead[]              @relation("CreatedBy")
  interactions     InteractionLog[]
  interactionEdits InteractionLogEdit[]
  assignmentsMade  AssignmentHistory[] @relation("AssignedBy")
  auditLogs        AuditLog[]

  @@index([email])
  @@index([branchId])
  @@index([role])
  @@index([isActive])
}

// ─────────────────────────────────────────
// COURSE
// Dynamic — admin adds/manages from dashboard.
// Not an enum because business changes this often.
// ─────────────────────────────────────────

model Course {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String?  @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leadCourses LeadCourse[]
}

// ─────────────────────────────────────────
// LEAD SOURCE TYPE
// Dynamic — admin manages.
// Pre-seeded with 10 types from your list.
// ─────────────────────────────────────────

model LeadSourceType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  leads Lead[]
}

// ─────────────────────────────────────────
// LEAD
// Core entity. Created progressively.
// Minimum fields at creation: name + phone.
// Everything else filled as relationship builds.
// ─────────────────────────────────────────

model Lead {
  id String @id @default(cuid())

  // Minimum required at creation
  studentName String
  phone       String
  fatherName  String?
  dateOfBirth DateTime?

  // Contact
  alternatePhone String?
  whatsappNumber String?
  email          String?

  // Demographics
  gender        Gender?
  maritalStatus MaritalStatus?

  // Address
  village  String?
  sector   String?
  city     String?
  district String?
  state    String?

  // Academic — quick capture at enquiry stage only
  qualification    QualificationLevel?
  schoolCollege    String?
  boardUniversity  String?
  passingYear      Int?
  percentage       Float?
  pcmPcbPercentage Float?

  // Lead meta
  sourceId    String?
  source      LeadSourceType? @relation(fields: [sourceId], references: [id])
  sourceOther String?
  status      LeadStatus      @default(NEW)
  purpose     String?
  remarks     String?

  // Follow-up
  nextFollowUpAt DateTime?
  sendSms        Boolean   @default(false)
  sendEmail      Boolean   @default(false)

  // Ownership
  branchId     String
  branch       Branch @relation(fields: [branchId], references: [id])
  assignedToId String?
  assignedTo   User?  @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User   @relation("CreatedBy", fields: [createdById], references: [id])

  // Duplicate handling — self referential
  // When duplicate detected:
  //   isDuplicate = true
  //   duplicateOfId = original lead id
  //   InteractionLog entry added to original lead noting the duplicate
  isDuplicate   Boolean @default(false)
  duplicateOfId String?
  duplicateOf   Lead?   @relation("Duplicates", fields: [duplicateOfId], references: [id])
  duplicates    Lead[]  @relation("Duplicates")

  // Confirmation tracking
  confirmedAt   DateTime?
  confirmedById String?   // User.id of who confirmed it

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  courses              LeadCourse[]
  interactions         InteractionLog[]
  assignments          AssignmentHistory[]
  auditLogs            AuditLog[]
  confirmedApplication ConfirmedApplication?

  // Indexes — every analytics query covered
  @@index([phone])           // duplicate detection
  @@index([email])           // duplicate detection
  @@index([status])          // filter by pipeline stage
  @@index([assignedToId])    // employee sees own leads
  @@index([branchId])        // branch-level reports
  @@index([createdAt])       // time-based analytics
  @@index([sourceId])        // lead source breakdown
  @@index([isDuplicate])     // filter real vs duplicate
  @@index([nextFollowUpAt])  // follow-up dashboard
}

// ─────────────────────────────────────────
// LEAD COURSE
// Many-to-many: one lead, many courses.
// isPrimary = main course of interest.
// ─────────────────────────────────────────

model LeadCourse {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([leadId, courseId])
  @@index([leadId])
  @@index([courseId])
}

// ─────────────────────────────────────────
// INTERACTION LOG
// The feedback/review system.
// ONE ROW = ONE FEEDBACK ENTRY.
// Infinite entries per lead per stage.
// Rows are NEVER hard deleted.
// Employees: add + edit own entries only.
// Admins: soft delete only.
// ─────────────────────────────────────────

model InteractionLog {
  id     String          @id @default(cuid())
  leadId String
  lead   Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId String
  user   User            @relation(fields: [userId], references: [id])
  type   InteractionType

  // Current note — always the latest version
  note String?

  // Call data
  // Now: employee manually uploads recording URL
  // Future: calls happen from LMS (Exotel/Twilio)
  callRecordingUrl String?
  callDurationSecs Int?
  callDirection    String? // INBOUND | OUTBOUND — for future LMS calling

  // Stage context — what status was lead in during this interaction
  statusBefore LeadStatus?
  statusAfter  LeadStatus?

  // Notification tracking
  smsSent   Boolean @default(false)
  emailSent Boolean @default(false)

  // Edit tracking — quick flag
  // Full history lives in InteractionLogEdit
  isEdited Boolean @default(false)

  // Soft delete — only ADMIN can trigger, never hard delete
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedById String?

  createdAt DateTime @default(now())

  // Full edit history — Option B
  editHistory InteractionLogEdit[]

  @@index([leadId])
  @@index([userId])
  @@index([createdAt])
  @@index([type])
  @@index([statusAfter])
  @@index([isDeleted])
}

// ─────────────────────────────────────────
// INTERACTION LOG EDIT
// Every edit to a note is stored here.
// noteBefore = what it said before this edit
// noteAfter  = what it was changed to
// Full version history — nothing ever lost.
// ─────────────────────────────────────────

model InteractionLogEdit {
  id               String         @id @default(cuid())
  interactionLogId String
  interactionLog   InteractionLog @relation(fields: [interactionLogId], references: [id], onDelete: Cascade)

  editedById String
  editedBy   User   @relation(fields: [editedById], references: [id])

  noteBefore String
  noteAfter  String

  editedAt DateTime @default(now())

  @@index([interactionLogId])
  @@index([editedAt])
}

// ─────────────────────────────────────────
// ASSIGNMENT HISTORY
// Every reassignment permanently logged.
// Only SUB_ADMIN and ADMIN can reassign.
// ─────────────────────────────────────────

model AssignmentHistory {
  id           String   @id @default(cuid())
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedById String
  assignedBy   User     @relation("AssignedBy", fields: [assignedById], references: [id])
  assignedToId String?
  reason       String?
  createdAt    DateTime @default(now())

  @@index([leadId])
  @@index([assignedById])
  @@index([createdAt])
}

// ─────────────────────────────────────────
// AUDIT LOG
// System-generated. Never user-written.
// Captures every significant action automatically.
// Old + new values stored as JSON for full diff.
// ─────────────────────────────────────────

model AuditLog {
  id     String  @id @default(cuid())
  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])
  userId String
  user   User    @relation(fields: [userId], references: [id])

  action   String  // LEAD_CREATED, STATUS_CHANGED, LEAD_ASSIGNED, etc.
  oldValue Json?
  newValue Json?

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─────────────────────────────────────────
// CONFIRMED APPLICATION
// Created ONLY when lead.status = CONFIRMED.
// Full admission form data lives here.
// 1-to-1 with Lead.
// Aadhar + Apaar ID collected here.
// This is what gets exported as PDF.
// ─────────────────────────────────────────

model ConfirmedApplication {
  id     String @id @default(cuid())
  leadId String @unique
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Identity
  aadharNo String?
  apaarId  String? // Apaar / ABC ID

  // Demographics captured in the confirmed application
  gender        Gender?
  maritalStatus MaritalStatus?

  // Family background
  motherName       String?
  motherOccupation String?
  motherIncome     Float?
  fatherOccupation String?
  fatherIncome     Float?
  noOfSisters      Int?
  noOfBrothers     Int?
  nationality      String?
  religion         String?
  category         String?

  // Addresses
  postalAddress        String?
  permanentAddress     String?
  permanentPhone       String?
  localGuardianName    String?
  localGuardianAddress String?
  localGuardianPhone   String?

  // Payment info
  bookingAmount     Float?
  bookingCashDDNo   String?
  bookingBank       String?
  bookingDate       DateTime?
  admissionAmount   Float?
  admissionCashDDNo String?
  admissionBank     String?
  admissionDate     DateTime?
  duesAmount        Float?
  dueDate           DateTime?

  // Extras
  extraCurricular String?
  authorisedBy    String?
  remarks         String?

  // Father's name (collected on admission form, separate from lead.fatherName)
  fatherName  String?

  // Auto-generated IDs assigned when lead becomes CONFIRMED
  fileNumber  String?  @unique  // e.g. 11/2026 (sequential per branch per year)
  admissionId String?  @unique  // e.g. S0001 (global sequential)

  // Admission form tracking
  isFormComplete     Boolean   @default(false)
  sentToStudentAt    DateTime?
  sentToStudentEmail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academicRecords AcademicRecord[]
  entranceExams   EntranceExamDetail[]
  documents       LeadDocument[]
}

// ─────────────────────────────────────────
// ACADEMIC RECORD
// One row per education level per student.
// Max 4 rows: Matric, Inter, Graduation, PG.
// Lives under ConfirmedApplication, not Lead.
// ─────────────────────────────────────────

model AcademicRecord {
  id                     String               @id @default(cuid())
  confirmedApplicationId String
  confirmedApplication   ConfirmedApplication @relation(fields: [confirmedApplicationId], references: [id], onDelete: Cascade)

  level       QualificationLevel
  stream      String?
  institution String?
  board       String?
  passingYear Int?
  percentage  Float?
  grade       String?

  createdAt DateTime @default(now())

  @@index([confirmedApplicationId])
}

// ─────────────────────────────────────────
// ENTRANCE EXAM DETAIL
// JEE, NEET etc. Multiple per student.
// Lives under ConfirmedApplication.
// ─────────────────────────────────────────

model EntranceExamDetail {
  id                     String               @id @default(cuid())
  confirmedApplicationId String
  confirmedApplication   ConfirmedApplication @relation(fields: [confirmedApplicationId], references: [id], onDelete: Cascade)

  examName String
  rollNo   String?
  score    String?
  rank     Int?

  createdAt DateTime @default(now())

  @@index([confirmedApplicationId])
}

// ─────────────────────────────────────────
// DOCUMENT TYPE
// Dynamic — admin manages.
// Pre-seeded: Marksheet, ID Proof, Photo.
// isRequired = must be uploaded before confirmation.
// ─────────────────────────────────────────

model DocumentType {
  id         String   @id @default(cuid())
  name       String   @unique
  isRequired Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  documents LeadDocument[]
}

// ─────────────────────────────────────────
// LEAD DOCUMENT
// Files per confirmed application.
// fileUrl = Supabase Storage URL.
// Verified by SUB_ADMIN or ADMIN only.
// ─────────────────────────────────────────

model LeadDocument {
  id                     String               @id @default(cuid())
  confirmedApplicationId String
  confirmedApplication   ConfirmedApplication @relation(fields: [confirmedApplicationId], references: [id], onDelete: Cascade)
  documentTypeId         String
  documentType           DocumentType         @relation(fields: [documentTypeId], references: [id])

  fileUrl    String
  fileName   String
  isVerified Boolean   @default(false)
  verifiedAt DateTime?
  verifiedBy String?

  uploadedAt DateTime @default(now())

  @@index([confirmedApplicationId])
  @@index([documentTypeId])
}

// ─────────────────────────────────────────
// REFRESH TOKEN
// One row per active device session.
// Max 3 per user.
// tokenHash = bcrypt of the actual token.
// Raw token is NEVER stored.
// lastUsedAt updated on every refresh.
// Expires after 1 day of inactivity.
// ─────────────────────────────────────────
model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  deviceInfo String?
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─────────────────────────────────────────
// PASSWORD RESET TOKEN
// Generated when: admin resets, forgot password
// One-time use only (usedAt set after use)
// Expires in 1 hour
// ─────────────────────────────────────────
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}