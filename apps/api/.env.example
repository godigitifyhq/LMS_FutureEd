# Core runtime
NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/futureed
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me

# CORS / frontend
CORS_ORIGIN=http://localhost:3000
API_BASE_URL=http://localhost:5000/api/v1
FRONTEND_URL=http://localhost:3000

# ── Email transport (set ONE of the two options below) ──────────────────────
#
# Option A — Resend (HTTPS, works on Render/cloud, free 3000/month)
#   Sign up at resend.com → API Keys → Create Key
#   Requires a verified sending domain (cannot send FROM @gmail.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
#
# Option B — SMTP via Brevo (free 300/day, no domain needed, works on Render)
#   Sign up at brevo.com → SMTP & API → SMTP → Generate credentials
#   Also works locally with Gmail App Password (SMTP_HOST=smtp.gmail.com)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login@email.com
SMTP_PASS=your-brevo-smtp-key
#
# Sender name shown in the inbox (any address for Brevo; verified domain for Resend)
SMTP_FROM="FutureEd LMS <noreply@yourdomain.com>"
#
# Optional: hosted logo URL for emails (falls back to embedded base64 if not set)
LOGO_URL=


